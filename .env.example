# PocketBase Admin Account (REQUIRED)
# -----------------------------------
# Set these to automatically create/update an admin account on first run
# Access the admin panel at http://localhost:8090/_/
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=changeme123

# -----------------------------------
# PocketBase URL (OPTIONAL - for mobile testing)
# -----------------------------------
# Only set this for mobile device testing (direct backend access)
# In development, Vite proxy handles routing automatically
# In Docker, nginx proxy handles routing automatically
# PUBLIC_POCKETBASE_URL=http://YOUR_LOCAL_IP:8090

# -----------------------------------
# SvelteKit Body Size Limit (OPTIONAL)
# -----------------------------------
# Maximum request body size (for uploads)
# Default: 500M
BODY_SIZE_LIMIT=500M

# -----------------------------------
# PocketBase Admin UI (OPTIONAL)
# -----------------------------------
# Expose the PocketBase admin UI at /_/ through the public domain
# Default: false (blocked for security)
# Set to true for self-hosted setups where you need browser access to the DB admin
EXPOSE_PB_ADMIN=false

# -----------------------------------
# PocketBase Batch API Settings (OPTIONAL)
# -----------------------------------
# Enable batch operations for better performance (reduces HTTP requests)
PB_BATCH_ENABLED=true
# Maximum number of operations per batch request
PB_BATCH_MAX_REQUESTS=100
# Timeout in seconds for batch operations
PB_BATCH_TIMEOUT=30
# Maximum body size in bytes (default: 128MB)
PB_BATCH_MAX_BODY_SIZE=134217728
